# PostgreSQL 连接字符串
# 本地开发时，使用 prisma/setup-database.sql 创建数据库和用户后，修改为：
# DATABASE_URL="postgresql://kite_user:your_password@localhost:5432/kite?schema=public"
DATABASE_URL="postgresql://kite_user:your_secure_password_here@localhost:5432/kite?schema=public"
AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_URL="http://localhost:3000"
KITE_SETUP_COMPLETE="false"
KITE_ALLOW_PUBLIC_REGISTRATION="false"
# systemd deployment can set this to /etc/kite/kite.env
KITE_ENV_FILE=".env"
